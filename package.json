{
  "name": "oh-my-pi-extends",
  "version": "1.0.0",
  "description": "OMP 配置一键导出/导入扩展（tar.gz 格式），支持选择项目、版本检查、自动备份",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "oxlint": "oxlint --fix src/",
    "oxfmt": "oxfmt --write src/",
    "check": "bun run tsc && bun run lint && bun run fmt:check",
    "lint": "bun run oxlint && bun run oxfmt"
  },
  "omp": {
    "extensions": [
      "src/index.ts"
    ]
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "^15.10.4",
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3"
  }
}